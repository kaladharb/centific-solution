# Production Environment Variables
# Copy this to .env and fill in your values

# Database
DB_PASSWORD=your-secure-database-password
DATABASE_URL=postgresql://voltedge:your-secure-database-password@db/voltedge_db

# Security
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-here-minimum-32-characters-long

# AI (Optional)
ANTHROPIC_API_KEY=sk-ant-api03-your-production-anthropic-key

# URLs
FRONTEND_URL=https://yourdomain.com
VITE_API_BASE_URL=https://yourdomain.com/api

# Ports (optional, defaults provided)
BACKEND_PORT=5000
FRONTEND_PORT=80